@{
    ViewData["Title"] = "Ver Publicación";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Publicacion.NombreProducto - Re-Estrena</title>
    <link rel="stylesheet" href="~/css/ver-publicacion.css">
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-left">
            <img src="~/images/logo.png" alt="Re-Estrena" class="logo">
            <span class="brand-name">RE-ESTRENA</span>
        </div>
        <nav class="header-nav">
            <a href='@Url.Action("VerPaginaPrincipalC", "Account")'>Vender</a>
            <a href="#" class="icon-button">🏷️</a>
            <a href="#" class="icon-button">🛒</a>
            <a href='@Url.Action("VerUsuarioC", "Account")' class="icon-button">👤</a>
            <a href='@Url.Action("VerNotificaciones", "Account")' class="icon-button">🔔</a>
            <a href='@Url.Action("VerMensajes", "Account")' class="icon-button">💬</a>
        </nav>
    </header>

    <main class="main-content">
        <div class="product-container">
            <!-- Columna izquierda: Imagen del producto -->
            <div class="product-image-section">
                <img src="@ViewBag.Publicacion.Imagen" alt="@ViewBag.Publicacion.NombreProducto" class="product-image">
            </div>

            <!-- Columna derecha: Información del producto -->
            <div class="product-info-section">
                <!-- Título y botón de favorito -->
                <div class="product-header">
                    <h1 class="product-title">@ViewBag.Publicacion.NombreProducto</h1>
                    <form asp-action="likear" asp-controller="Account" method="post" class="like-form">
                        <input type="hidden" name="idPublicacion" value="@ViewBag.Publicacion.Id">
                        <button type="submit" class="btn-favorite">❤️</button>
                    </form>
                </div>

                <!-- Descripción -->
                <div class="product-description">
                    <p>@Html.Raw(ViewBag.Publicacion.Descripcion?.Replace("\n", "<br>") ?? "Sin descripción")</p>
                </div>

                <!-- Etiquetas/Categorías -->
                <div class="product-tags">
                    <h3>Etiquetas/categorías:</h3>
                    <div class="tags-list">
                        @if (ViewBag.Publicacion.Etiquetas != null)
                        {
                            @foreach (var etiqueta in ViewBag.Publicacion.Etiquetas.Split(','))
                            {
                                <span class="tag">@etiqueta.Trim()</span>
                            }
                        }
                    </div>
                </div>

                <!-- Información del vendedor -->
                <div class="seller-info">
                    <p><strong>Vendedor:</strong> <span class="seller-name">@ViewBag.Publicacion.NombreVendedor</span></p>
                </div>

                <!-- Precio y botón de compra -->
                <div class="product-footer">
                    <div class="price-section">
                        <span class="price-label">Precio:</span>
                        <span class="price-value">$@ViewBag.Publicacion.Precio</span>
                    </div>
                    <form asp-action="AgregarACarrito" asp-controller="Purchase" method="post">
                        <input type="hidden" name="idPublicacion" value="@ViewBag.Publicacion.Id">
                        <button type="submit" class="btn-add-to-cart">Agregar al carrito</button>
                    </form>
                </div>

                <!-- Botón para agregar a lista (wishlist) -->
                <div>
                    <button class="btn-send">📤</button>
                </div>
            </div>
        </div>
    </main>

</body>
</html>
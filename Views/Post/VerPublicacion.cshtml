@{
    ViewData["Title"] = "Ver Publicación";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Publicacion.NombreProducto - Re-Estrena</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header class="header-VP">
        <div>
            <img src="~/images/logo.png" alt="Re-Estrena" class="logo">
            <p>RE-ESTRENA</p>
        </div>
        <nav>
            <a href='@Url.Action("VerPaginaPrincipalC", "Account")'>Vender</a>
            <a href='@Url.Action("VerCarrito", "Purchase")'><img src="cart_icon.png" alt="Carrito" title="Carrito"></a>
            <a href='@Url.Action("VerUsuarioC", "Account")'><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a>
            <a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a>
            <a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a>
            <a href='@Url.Action("CerrarSesion", "OnBoarding")'><img src="logout_icon.png" alt="Cerrar sesión" title="Cerrar sesión"></a>
        </nav>
    </header>

    <main class="main-content">
        <section class="product-container">
            <div class="product-image-section">
                <img src="@ViewBag.Publicacion.Imagen" alt="@ViewBag.Publicacion.NombreProducto" class="product-image">
            </div>

            <div class="product-info-section">

                <div class="product-header">
                    <h1 class="product-title">@ViewBag.Publicacion.NombreProducto</h1>
                    <form asp-action="likear" asp-controller="Account" method="post">
                        <input type="hidden" name="idPublicacion" value="@ViewBag.Publicacion.IdPublicacion">
                        <button type="submit">❤️</button>
                    </form>
                </div>

                <div class="product-description">
                    <p>@Html.Raw(ViewBag.Publicacion.Descripcion?.Replace("\n", "<br>") ?? "Sin descripción")</p>
                </div>

                <div class="product-tags">
                    <h3>Etiquetas/categorías:</h3>
                    <div class="tags-list">
                        @if (ViewBag.Publicacion.Etiquetas != null)
                        {
                            @foreach (var etiqueta in ViewBag.Publicacion.Etiquetas.Split(','))
                            {
                                <p class="tag">@etiqueta.Trim()</p>
                            }
                        }
                    </div>
                </div>

                <!-- Información del vendedor -->
                <div class="seller-info">
                    <p><strong>Vendedor:</strong> <p class="seller-name">@ViewBag.Publicacion.NombreVendedor</p></p>
                </div>

                <!-- Precio y botón de compra -->
                <div class="product-footer">
                    <div>
                        <p class="price-label">Precio:</p>
                        <p class="price-value">$@ViewBag.Publicacion.Precio</p>
                    </div>
                    <form asp-action="AgregarACarrito" asp-controller="Purchase" method="post">
                        <input type="hidden" name="idPublicacion" value="@ViewBag.Publicacion.Id">
                        <button type="submit" class="btn-add-to-cart">Agregar al carrito</button>
                    </form>
                </div>

                <!-- Botón para agregar a lista (wishlist) -->
                <div>
                    <button>📤</button>
                </div>
            </div>
        </section>
    </main>

</body>
</html>
@{
    ViewData["Title"] = "Ver Publicación";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Publicacion.NombreProducto - Re-Estrena</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header>
        <div>
            <a href="@Url.Action("VerPaginaPrincipalC", "Account")">
                <img src="~/imagenes/logo.png" alt="Logo Re-Estrena">
                <h1>Re-Estrena</h1>
            </a>
            <nav>
                <ul>
                    <li><a href='@Url.Action("VerPaginaPrincipalV", "Account")'>Vender</a></li>
                    <li><a href='@Url.Action("VerCarrito", "Purchase")'><img src="cart_icon.png" alt="Carrito" title="Carrito"></a></li>
                    <li><a href='@Url.Action("VerUsuarioC", "Account")'><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a></li>
                    <li><a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a></li>
                    <li><a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="verPublicacion">
            <div class="imagen-producto">
                <img src="@ViewBag.Publicacion.Foto" alt="@ViewBag.Publicacion.NombreProducto">
            </div>
            <div>
                <h2>@ViewBag.Publicacion.NombreProducto</h2>
                <p class="info-texto">@ViewBag.Publicacion.Descripcion</p>
            </div>
            <div class="tags-area">
                @* Este campo no está en la clase Publicacion, lo simulamos o asumimos que viene en otra ViewBag o debe ser renderizado aparte. *@
                <p style="margin: 0;">#cartera #citybag #mujer #marron #isabelmarant</p>
            </div>
            <div class="pie-item">
                <p>Precio: <b>$@ViewBag.Publicacion.Precio</b></p>
            </div>
        </section>
    </main>

</body>
</html>
@{
    ViewData["Title"] = "Subir publicación";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header>
        <div>
            <a href="@Url.Action("VerPaginaPrincipalV", "Account")">
                <img src="~/imagenes/logo.png" alt="Logo Re-Estrena">
                <h1>Re-Estrena</h1>
            </a>
            <nav>
                <ul>
                    <li><a href='@Url.Action("VerPaginaPrincipalC", "Account")'>Comprar</a></li>
                    <li><a href='@Url.Action("subirPublicacion", "Post")'><img src="cart_icon.png" alt="Subir" title="Subir"></a></li>
                    <li><a href='@Url.Action("VerPaginaPrincipalV", "Account")'><img src="cart_icon.png" alt="Usuario" title="Usuario"></a></li>
                    <li><a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a></li>
                    <li><a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="subirPublicacion">
            <form action="/Post/subirPublicacionGuardar" method="post" enctype="multipart/form-data">
                <div>
                    <label for="foto">Subir foto</label>
                    <input type="text" id="foto" name="foto" placeholder="foto">
                    <textarea id="descripcion" name="descripcion" rows="8" cols="30" placeholder="Información del producto"></textarea>
                    <input type="text" id="nombreProducto" name="nombreProducto" placeholder="Nombre del producto">
                    <input type="text" id="etiquetas" name="etiquetas" placeholder="Agregar etiquetas">
                    <label for="precio">Precio:</label>
                    <input type="number" id="precio" name="precio" placeholder="0.00" min="0" step="0.01">
                </div>
                <button type="submit">Subir publicación</button>
            </form>
        </section>
    </main>

</body>
</html>

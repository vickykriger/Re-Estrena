@{
    ViewData["Title"] = "Subir publicación";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header>
        <div class="main-header">
            <a href="@Url.Action("VerPaginaPrincipalV", "Account")">
                <img src="~/imagenes/logo.png" alt="Logo Re-Estrena">
                <h1>Re-Estrena</h1>
            </a>
            <nav>
                <a href='@Url.Action("VerPaginaPrincipalC", "Account")'>Comprar</a>
                <a href='@Url.Action("SubirPublicacion", "Post")'><img src="plus_icon.png" alt="Subir" title="Subir publicación"></a>
                <a href='@Url.Action("VerUsuarioV", "Account")'><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a>
                <a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a>
                <a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main-container">
        <div class="publicar-container">
            <!-- Botón de eliminar (solo visible en modo edición) -->
            <button type="button" class="btn-eliminar" id="btnEliminar" style="display: none;">
                🗑️
            </button>

            <form asp-action="subirPublicacion" asp-controller="Post" method="post" enctype="multipart/form-data" class="publicar-form">
                <!-- Sección de imagen -->
                <div class="imagen-section">
                    <div class="imagen-preview" id="imagePreview">
                        <input type="file" name="imagen" id="inputImagen" accept="image/*" class="input-file" required>
                        <label for="inputImagen" class="btn-subir-foto">
                            <span class="icon">📷</span> Subir foto
                        </label>
                        <img id="previewImg" class="preview-img" style="display: none;" alt="Preview">
                    </div>
                </div>

                <!-- Sección de información -->
                <div class="info-section">
                    <!-- Información del producto -->
                    <div class="form-group">
                        <label for="informacion">Información del producto</label>
                        <textarea name="informacion" id="informacion" rows="6" class="form-control" placeholder="Describe tu producto..." required></textarea>
                    </div>

                    <!-- Agregar etiquetas -->
                    <div class="form-group">
                        <label for="etiquetas">Agregar etiquetas</label>
                        <input type="text" name="etiquetas" id="etiquetas" class="form-control" placeholder="Ej: casual, verano, algodón">
                    </div>

                    <!-- Precio -->
                    <div class="form-group">
                        <label for="precio">Precio:</label>
                        <input type="number" name="precio" id="precio" class="form-control" placeholder="$0" min="0" step="0.01" required>
                    </div>

                    <!-- Botón de submit -->
                    <button type="submit">Subir publicación</button>
                </div>
            </form>
        </div>
    </main>

</body>
</html>

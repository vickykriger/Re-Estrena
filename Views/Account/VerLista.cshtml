@{
    ViewData["Title"] = ViewBag.NombreLista ?? "Mi Lista";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.NombreLista - Re-Estrena</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header>
        <div>
            <a href="@Url.Action("VerPaginaPrincipalC", "Account")">
                <img src="~/imagenes/logo.png" alt="Logo Re-Estrena">
                <h1>Re-Estrena</h1>
            </a>
            <nav>
                <ul>
                    <li><a href='@Url.Action("VerPaginaPrincipalV", "Account")'>Vender</a></li>
                    <li><a href='@Url.Action("VerCarrito", "Purchase")'><img src="cart_icon.png" alt="Carrito" title="Carrito"></a></li>
                    <li><a href='@Url.Action("VerUsuarioC", "Account")'><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a></li>
                    <li><a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a></li>
                    <li><a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a></li>
                </ul>
            </nav>
        </div>
    </header>

    <section class="container">
        <div>
            <h1>@ViewBag.NombreLista:</h1>
        </div>

        @if (ViewBag.Publicacion != null && ((List<dynamic>)ViewBag.Publicacion).Count > 0)
        {
            <div class="productos-grid">
                @foreach (var publicacion in ViewBag.Publicacion)
                {
                    <div class="producto-card">
                        <a href='@Url.Action("verPublicacion", "Post", new { idPublicacion = publicacion.Id })'>
                            <div>
                                @if (!string.IsNullOrEmpty(publicacion.Foto))
                                {
                                    <img src="@publicacion.Foto" alt="@publicacion.NombreProducto">
                                }
                                else
                                {
                                    <img src="/placeholder.svg?height=200&width=200" alt="Producto sin imagen">
                                }
                            </div>
                        </a>

                        <div>
                            <h3>@publicacion.NombreProducto</h3>
                            <p class="producto-descripcion">@publicacion.Descripcion</p>
                            <div>
                                <form asp-controller="Purchase" asp-action="AgregarACarrito" method="post">
                                    <input type="hidden" name="idPublicacion" value="@publicacion.Id" />
                                    <button type="submit" class="precio-btn">$@publicacion.Precio</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <p>Esta lista está vacía. ¡Empieza a agregar productos!</p>
                <a href='@Url.Action("VerPaginaPrincipalC", "Account")'>Explorar productos</a>
            </div>
        }
    </section>

</body>
</html>

@{
    ViewBag.Title = "Ofertas - Re-Estrena";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header>
        <div>
            <a href="@Url.Action("VerPaginaPrincipalC", "Account")">
                <img src="~/imagenes/logo.png" alt="Logo Re-Estrena" element>
                <h1>Re-Estrena</h1>
            </a>
            <nav>
                <ul>
                    <li><a href='@Url.Action("VerPaginaPrincipalV", "Account")'>Vender</a></li>
                    <li><a href='@Url.Action("VerCarrito", "Purchase")'><img src="cart_icon.png" alt="Carrito" title="Carrito"></a></li>
                    <li><a href='@Url.Action("VerUsuarioC", "Account")'><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a></li>
                    <li><a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a></li>
                    <li><a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a></li>
                </ul>
            </nav>
        </div>
    </header>
    <main class="ofertas-container">
        <form method="get" action='@Url.Action("buscarProducto", "Account")'>
            <input type="text" name="descripcion" placeholder="Buscar productos..." />
            <button type="submit">🔍</button>
        </form>
        <div>
            <h2>Ofertas</h2>
        </div>

        <section class="productos-grid">
            @if (ViewBag.Publicaciones != null && ViewBag.Publicaciones.Count > 0)
            {
                foreach (var publicacion in ViewBag.Publicaciones)
                {
                    <article>
                        <div>
                            <h3>@publicacion.Titulo</h3>
                            <form method="post" action='@Url.Action("likear", "Account")' class="favorito-form">
                                <input type="hidden" name="idPublicacion" value="@publicacion.IdPublicacion" />
                                <button type="submit">❤️</button>
                            </form>
                        </div>
                        
                       
                        <a href='@Url.Action("verPublicacion", "Post", new { idPublicacion = publicacion.IdPublicacion })'>
                            <div class="producto-imagen">
                                @if (!string.IsNullOrEmpty(publicacion.Foto))
                                {
                                    <img src="@publicacion.Foto" alt="@publicacion.NombreProducto" />
                                }
                                else
                                {
                                    <img src="/placeholder.svg?height=200&width=200" alt="@publicacion.NombreProducto" />
                                }
                            </div>
                        </a>

                        <section class="producto-info">
                            <p>@publicacion.Descripcion</p>
                            
                            <div>
                                <p>Foto: @publicacion.Foto</p>
                                <p>Precio: @publicacion.Precio</p>
                            </div>

                            <div class="producto-carrito">
                                <form method="post" action='@Url.Action("AgregarACarrito", "Purchase")'>
                                    <input type="hidden" name="idPublicacion" value="@publicacion.IdPublicacion" />
                                    <button type="submit">${@publicacion.Precio}</button>
                                </form>
                            </div>
                        </section>
                    </article> 
                }
            }
            else
            {
                <p>No hay ofertas disponibles en este momento.</p>
            }
        </section>
    </main>
    
   <div class="grid-ofertas">
        
        <div class="publicacion-card">
            <div class="card-header">
                <h3>Tartan Whisper</h3>
                <div class="actions">
                    <span style="color: gold;">&#9733;</span> 
                    <span style="color: #d1463e;">&#9829;</span> 
                </div>
            </div>
            <div class="card-image-container">
                <img src="scarf_tartan_whisper.jpg" alt="Bufanda de lana escocesa">
            </div>
            <div class="card-description">
                <p>Bufanda de lana con clásico estampado escocés.</p>
            </div>
            <div class="card-footer">
                <div class="card-tags">
                    <p>#bufanda</p>
                    <p>#rojo</p>
                    <p>#glamour</p>
                </div>
                <div class="card-price">$45</div>
            </div>
        </div>

        <div class="publicacion-card">
            <div class="card-header">
                <h3>Denim Daze</h3>
                <div class="actions">
                    <span style="color: gold;">&#9733;</span> 
                    <span style="color: #d1463e;">&#9829;</span> 
                </div>
            </div>
            <div class="card-image-container">
                <img src="denim_shorts.jpg" alt="Shorts de mezclilla deshilachados">
            </div>
            <div class="card-description">
                <p>Short de mezclilla azul con diseño deshilachado y ruedo destructivo.</p>
            </div>
            <div class="card-footer">
                <div class="card-tags">
                    <p>#denim</p>
                    <p>#azul</p>
                    <p>#short</p>
                </div>
                <div class="card-price">$50</div>
            </div>
        </div>

        <div class="publicacion-card">
            <div class="card-header">
                <h3>Olive Mirage</h3>
                <div class="actions">
                    <span style="color: gold;">&#9733;</span> 
                    <span style="color: #d1463e;">&#9829;</span> 
                </div>
            </div>
            <div class="card-image-container">
                <img src="olive_jacket.jpg" alt="Chaqueta bomber verde y beige">
            </div>
            <div class="card-description">
                <p>Chaqueta liviana estilo retro en tonos beige y verde oliva.</p>
            </div>
            <div class="card-footer">
                <div class="card-tags">
                    <p>#beige</p>
                    <p>#chaqueta</p>
                    <p>#militar</p>
                </div>
                <div class="card-price">$150</div>
            </div>
        </div>

    </div>
</body>
</html>
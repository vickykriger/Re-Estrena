@{
    ViewData["Title"] = "Re-Estrena - Perfil Vendedor";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="site.css">
</head>
<body>
    <header>
            <div class="logo-section">
                <img src="~/images/logo.png" alt="Logo Re-Estrena">
                <h1>RE-ESTRENA</h1>
            </div>
           <div class="header-bar">
      <img src="logo.png" alt="Logo Re-Estrena" class="logo">
      <h1>RE-ESTRENA</h1>
      <nav>
        <a href='@Url.Action("VerPaginaPrincipalC", "Account")'>Comprar</a>
        <a href='@Url.Action("SubirPublicacion", "Post")'><img src="plus_icon.png" alt="Subir" title="Subir publicación"></a>
        <a href='@Url.Action("VerCarrito", "Purchase")'><img src="cart_icon.png" alt="Carrito" title="Carrito"></a>
        <a href='@Url.Action("VerUsuarioV", "Account")'><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a>
        <a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a>
        <a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a>
        <a href='@Url.Action("CerrarSesion", "OnBoarding")'><img src="logout_icon.png" alt="Cerrar sesión" title="Cerrar sesión"></a>
      </nav>
    </div>
    </header>

    <main>
        <section class="perfil">
            <div>
                <div class="foto-perfil">
                    <img src='@(ViewBag.Usuario.FotoPerfil ?? "  ~/images/default-avatar.png")" alt="Foto de perfil'>
                    <form asp-action="subirFoto" asp-controller="Account" method="post" enctype="multipart/form-data">
                        <label for="foto-upload">Subir foto</label>
                        <input type="file" id="foto-upload" name="foto" accept="image/*" onchange="this.form.submit()">
                    </form>
                </div>

                <section class="datos-perfil">
                    <div>
                        <div>
                            <h2>@ViewBag.Usuario.Nombre</h2>
                            <p class="username">@("@" + ViewBag.Usuario.Username)</p>
                        </div>
                        <button>✎</button>
                        <button>⚙</button>
                    </div>

                    <div id="descripcion-vista">
                        <p>@Html.Raw(ViewBag.Usuario.Descripcion?.Replace("\n", "<br>") ?? "Sin descripción")</p>
                    </div>

                    <div id="descripcion-editar">
                        <form asp-action="editarUsuario" asp-controller="Account" method="post">
                            <textarea name="descripcion" rows="5" placeholder="Escribe tu descripción...">@ViewBag.Usuario.Descripcion</textarea>
                            <input type="hidden" name="userId" value="@ViewBag.Usuario.Id" />
                            <div>
                                <button type="submit">Guardar</button>
                                <button type="button">Cancelar</button>
                            </div>
                        </form>
                    </div>
                </section>
            </div>
        </section>

        <section class="publicaciones">
            <h3>Tus publicaciones</h3>

            <div>
                @{
                    if (ViewBag.PublicacionesPropias != null && ViewBag.PublicacionesPropias.Count > 0)
                    {
                        foreach (var publicacion in ViewBag.PublicacionesPropias)
                        {
                            <article>
                                <h4>@publicacion.NombreProducto</h4>
                                <a href='@Url.Action("editarPublicacion", "Post", new { id = publicacion.IdPublicacion })'>✎</a>
                                <img src="@publicacion.Foto" alt="@publicacion.NombreProducto">
                                <p>@publicacion.Descripcion</p>
                                <p>$@publicacion.Precio</p>
                            </article>
                        }
                    }
                    else
                    {
                        <p>Aún no tienes publicaciones. ¡Crea tu primera publicación!</p>
                    }
                }
            </div>

            <div class="agregar-publicacion">
                <a href='@Url.Action("subirPublicacion", "Post")' >+ Crear nueva publicación</a>
            </div>
        </section>

        <div>
            <form asp-action="cerrarSesion" asp-controller="OnBoarding" method="post">
                <button type="submit">Cerrar sesión</button>
            </form>
        </div>
    </main>
</body>
</html> 
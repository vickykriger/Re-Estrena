<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notificaciones vendedor - Re-Estrena</title>
  <link rel="stylesheet" href="estilo.css">
</head>

<body class="body-notificaciones">
  <header>
    <div class="header-bar">
      <img src="logo.png" alt="Logo Re-Estrena" class="logo">
      <h1>RE-ESTRENA</h1>
      <nav class="menu-bar">
        <a href="@Url.Action('VerPaginaPrincipalC', 'Home')">Comprar</a>
        <a href="@Url.Action('SubirPublicacion', 'Publicacion')"><img src="plus_icon.png" alt="Subir" title="Subir publicación"></a>
        <a href="@Url.Action('VerCarrito', 'Carrito')"><img src="cart_icon.png" alt="Carrito" title="Carrito"></a>
        <a href="@Url.Action('VerUsuario', 'Usuario')"><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a>
        <a href="@Url.Action('VerNotificaciones', 'Notificaciones')"><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a>
        <a href="@Url.Action('VerMensajes', 'Mensajes')"><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a>
        <a href="@Url.Action('CerrarSesion', 'Account')"><img src="logout_icon.png" alt="Cerrar sesión" title="Cerrar sesión"></a>
      </nav>
    </div>
  </header>

  <main>
  <section>
    <h2>Notificaciones</h2>
    <ul>
      @if(ViewBag.Notificaciones != null)
      {
        foreach(var notif in ViewBag.Notificaciones)
        {
          <li>
            <div>
              <p>@notif.Mensaje</p>
              <p>@notif.Fecha.ToString("dd/MM")</p>
            </div>
          </li>
        }
      }
      else
      {
        <li>No hay notificaciones.</li>
      }
    </ul>
  </section>
</main>

<footer>
  <p> &copy; Copyright - Todos los derechos reservados a Re-Estrena</p>
</footer>
</body>

</html>
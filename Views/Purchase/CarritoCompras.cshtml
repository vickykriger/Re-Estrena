@{
    ViewData["Title"] = "Carrito de Compras";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header>
        <div class="main-header">
            <a href="@Url.Action("VerPaginaPrincipalC", "Account")">
                <img src="~/imagenes/logo.png" alt="Logo Re-Estrena">
                <h1>Re-Estrena</h1>
            </a>
            <nav>
                <a href='@Url.Action("VerPaginaPrincipalV", "Account")'>Vender</a>
                <a href='@Url.Action("VerCarrito", "Purchase")'><img src="cart_icon.png" alt="Carrito" title="Carrito"></a>
                <a href='@Url.Action("VerUsuarioC", "Account")'><img src="user_icon.png" alt="Usuario" title="Perfil usuario"></a>
                <a href='@Url.Action("VerNotificaciones", "Account")'><img src="bell_icon.png" alt="Notificaciones" title="Notificaciones"></a>
                <a href='@Url.Action("VerMensajes", "Account")'><img src="msg_icon.png" alt="Mensajes" title="Mensajes"></a>
            </nav>
        </div>
    </header>

    <!-- Carrito Content -->
    <div class="carrito-container">
        @if (ViewBag.Carrito != null && ViewBag.Carrito.Count > 0)
        {
            <!-- Lista de productos -->
            <div class="productos-lista">
                @foreach (var publicacion in ViewBag.Carrito)
                {
                    <div class="producto-item">
                        <img src="@publicacion.Imagen" alt="@publicacion.NombreProducto" class="producto-imagen">
                        <div class="producto-info">
                            <h3 class="producto-nombre">@publicacion.NombreProducto</h3>
                            <p class="producto-vendedor">@publicacion.VendedorUsername</p>
                        </div>
                        <form method="post" asp-controller="Purchase" asp-action="EliminarDeCarrito" class="eliminar-form">
                            <input type="hidden" name="id" value="@publicacion.Id" />
                            <button type="submit" class="btn-eliminar">🗑️</button>
                        </form>
                        <div class="producto-precio">${@publicacion.Precio}</div>
                    </div>
                }
            </div>


            <div class="resumen-container">
                @foreach (var publicacion in ViewBag.Carrito)
                {
                    <div class="resumen-item">
                        <span>@publicacion.NombreProducto</span>
                        <span>$@publicacion.Precio</span>
                    </div>
                }
                
                <div class="resumen-item">
                    <span>Envío</span>
                    <span>$@ViewBag.Carrito[0].Precio</span>
                </div>
                <div class="resumen-item resumen-total">
                    <span><strong>Total</strong></span>
                    <span><strong>${@ViewBag.Total}</strong></span>
                </div>

                <button class="btn-continuar">Continuar compra</button>
            </div>
        }
        else
        {
            <div class="carrito-vacio">
                <p>Tu carrito está vacío</p>
            </div>
        }
    </div>

</body>
</html>